@page "/bogorov-rhythm"
@inject IJSRuntime JS
@inject HttpClient Http
@implements IAsyncDisposable

<div class="page-wrap">

    @if (!GameStarted)
    {
        <div class="map-select">
            <h2>Choose a Song</h2>

            <div class="map-grid">
                @{
                    var accentColors = new[] { "#ff5d8f", "#ffd447", "#5dc8ff" };
                }
                @for (int i = 0; i < AvailableMaps.Count; i++)
                {
                    var map = AvailableMaps[i];
                    var accent = accentColors[i % accentColors.Length];

                    <button class="map-card" style="--accent:@accent" @onclick="() => SelectMap(map)">
                        <div class="map-card-top"></div>
                        <div class="map-title">@map.Title</div>
                        <div class="eq-bars" aria-hidden="true">
                            <span></span><span></span><span></span><span></span>
                        </div>
                        <div class="map-cta">Tap to play</div>
                    </button>
                }
            </div>

            @if (LoadError != null)
            {
                <div class="load-error">@LoadError</div>
            }
        </div>
    }
    else
    {
        <div class="rhythm-container">

            <div class="rhythm-header">
                <button class="back-btn" @onclick="BackToMenu">← Menu</button>

                <div class="mode-box">
                    NOTES
                </div>

                <div class="volume-control">
                    <span class="volume-icon" aria-hidden="true">🔊</span>
                    <input id="volume-slider" class="volume-slider" type="range" min="0" max="100" value="100" aria-label="Song volume" />
                </div>
            </div>

            <div class="canvas-wrap">
                <canvas id="rhythmCanvas"></canvas>

                <div class="game-overlay">
                    <div class="glow-top"></div>
                </div>
            </div>

            @if (CurrentMap != null && !string.IsNullOrEmpty(CurrentMap.AudioFile))
            {
                <audio @ref="_audioRef" src="@("audio/" + CurrentMap.AudioFile)" preload="auto"></audio>
            }

            <div class="instructions">
                Press <kbd>A</kbd> <kbd>S</kbd> <kbd>D</kbd> to hit notes.
                Tap bubbles, spin circles, and drag paths to score extra combo.
            </div>

        </div>
    }

</div>

@code {
    // ---- state referenced by the markup above ----
    private bool GameStarted;
    private List<MapInfo> AvailableMaps = new();
    private string? LoadError;
    private MapInfo? CurrentMap;

    private ElementReference _audioRef;

    // ---- JS interop plumbing ----
    private IJSObjectReference? _module;
    private IJSObjectReference? _gameInstance;
    private DotNetObjectReference<BogorovRhythm>? _dotNetRef;
    private bool _needsGameInit;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Adjust this path/shape to however you actually list your songs -
            // this assumes a manifest listing Title/AudioFile/MapFile per song.
            AvailableMaps = await Http.GetFromJsonAsync<List<MapInfo>>("maps/manifest.json") ?? new();
        }
        catch (Exception ex)
        {
            LoadError = $"Could not load song list: {ex.Message}";
        }
    }

    private void SelectMap(MapInfo map)
    {
        LoadError = null;
        CurrentMap = map;
        GameStarted = true;
        _needsGameInit = true; // actual JS creation happens in OnAfterRenderAsync, once the canvas/audio elements exist
    }

    private async Task BackToMenu()
    {
        await TeardownGameAsync();
        GameStarted = false;
        CurrentMap = null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/BogorocRhytm.js");
        }

        if (_needsGameInit && CurrentMap is not null && _module is not null)
        {
            _needsGameInit = false;
            await InitGameAsync();
        }
    }

    private async Task InitGameAsync()
    {
        if (_module is null || CurrentMap is null) return;

        MapData? mapData;
        try
        {
            // Adjust this path to wherever your per-song note/bubble/segment JSON lives.
            mapData = await Http.GetFromJsonAsync<MapData>($"maps/{CurrentMap.MapFile}");
        }
        catch (Exception ex)
        {
            LoadError = $"Could not load map data for {CurrentMap.Title}: {ex.Message}";
            GameStarted = false;
            StateHasChanged();
            return;
        }

        _dotNetRef = DotNetObjectReference.Create(this);

        _gameInstance = await _module.InvokeAsync<IJSObjectReference>(
            "createBogorocRhytm",
            "rhythmCanvas",
            mapData,
            _audioRef,
            _dotNetRef);

        // The slider only exists in the DOM once GameStarted flips to true and
        // this render has completed - safe to wire it up right here.
        await _gameInstance.InvokeVoidAsync("bindVolumeSlider", "volume-slider");
    }

    // Called from the JS side (dotNetRef.invokeMethodAsync("OnGameFinished", ...)) when a song ends.
    [JSInvokable]
    public void OnGameFinished(int score, int maxCombo)
    {
        // Hook up whatever results/summary UI you want here.
        StateHasChanged();
    }

    private async Task TeardownGameAsync()
    {
        if (_gameInstance is not null)
        {
            try { await _gameInstance.InvokeVoidAsync("dispose"); } catch { /* element may already be gone */ }
            await _gameInstance.DisposeAsync();
            _gameInstance = null;
        }

        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }

    public async ValueTask DisposeAsync()
    {
        await TeardownGameAsync();

        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { /* circuit may already be gone */ }
        }
    }

    // ---- data models - shape these to match your actual JSON files ----
    public class MapInfo
    {
        public string Title { get; set; } = "";
        public string AudioFile { get; set; } = "";
        public string MapFile { get; set; } = "";
    }

    public class MapData
    {
        public int? TravelTimeMs { get; set; }
        public int? DurationMs { get; set; }
        public List<NoteData> Notes { get; set; } = new();
        public List<BubbleData> Bubbles { get; set; } = new();
        public List<SegmentData> Segments { get; set; } = new();
    }

    public class NoteData
    {
        public string Type { get; set; } = "tap"; // "tap" or "hold"
        public int Lane { get; set; }
        public int Time { get; set; }
        public int? HoldMs { get; set; }
    }

    public class BubbleData
    {
        public string Type { get; set; } = "tap"; // "tap", "spin", or "drag"
        public int Time { get; set; }
        public int Duration { get; set; }
        public double X { get; set; }
        public double Y { get; set; }
        public List<PathPoint>? Path { get; set; } // only used by "drag" bubbles
    }

    public class PathPoint
    {
        public double X { get; set; }
        public double Y { get; set; }
    }

    public class SegmentData
    {
        public int Start { get; set; }
        public int End { get; set; }
    }
}
