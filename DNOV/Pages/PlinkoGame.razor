@page "/plinko"
@namespace DNOV.Pages
@implements IAsyncDisposable

<h3>Plinko</h3>

<div class="plinko-layout">

    <!-- Game Board -->
    <div class="plinko-board">
        <p>Money: <strong>€@euro.ToString("F2")</strong></p>
        <p>Ball Cost: <strong>€@BallCost.ToString("F2")</strong></p>
        <button @onclick="DropBall" disabled="@(euro < BallCost)">
            Drop Ball (€@BallCost.ToString("F2"))
        </button>
        <br /><br />
        <canvas id="plinkoCanvas"
                style="border:2px solid #111111; border-radius:8px; width:100%; max-width:480px; display:block;">
        </canvas>
    </div>

    <!-- Upgrades Panel -->
    <div class="plinko-upgrades">
        <h4>⬆️ Upgrades</h4>
        @foreach (var upg in Upgrades)
        {
            <div class="upgrade-card">
                <strong>@upg.Icon @upg.Name</strong>
                <span class="upgrade-level">Lv @upg.CurrentLevel / @upg.MaxLevel</span>
                <div class="upgrade-desc">@upg.Description</div>

                <div class="upgrade-pips">
                    @for (int i = 0; i < upg.MaxLevel; i++)
                    {
                        <div class="pip @(i < upg.CurrentLevel ? "pip-filled" : "")"></div>
                    }
                </div>

                @if (!upg.IsMaxed)
                {
                    <button @onclick="() => BuyUpgrade(upg)"
                            disabled="@(!upg.CanAfford(euro))"
                            class="buy-btn">
                        Buy — €@upg.CurrentCost.ToString("F0")
                    </button>
                }
                else
                {
                    <span class="maxed-label">✅ MAXED</span>
                }
            </div>
        }
    </div>
</div>

<style>
    .plinko-layout {
        display: flex;
        gap: 20px;
        align-items: flex-start;
        flex-wrap: wrap;
    }

    .plinko-board {
        flex: 1 1 300px;
        min-width: 0;
    }

    .plinko-upgrades {
        flex: 1 1 280px;
        max-height: 560px;
        overflow-y: auto;
        color: black;
        min-width: 0;
    }

    .upgrade-card {
        border: 1px solid #444;
        border-radius: 6px;
        padding: 8px;
        margin-bottom: 6px;
        background: #1a1a2e;
        color: white;
    }

    .upgrade-level {
        color: #a78bfa;
        margin-left: 6px;
    }

    .upgrade-desc {
        font-size: 0.8em;
        color: #ccc;
        margin: 2px 0;
    }

    .upgrade-pips {
        display: flex;
        gap: 2px;
        margin: 4px 0;
        flex-wrap: wrap;
    }

    .pip {
        width: 16px;
        height: 6px;
        border-radius: 2px;
        background: #333;
    }

    .pip-filled {
        background: #7c3aed;
    }

    .buy-btn {
        font-size: 0.8em;
    }

    .maxed-label {
        color: #22c55e;
        font-size: 0.8em;
    }

    @@media (max-width: 600px) {
        .plinko-layout {
            flex-direction: column;
        }

        .plinko-upgrades {
            max-height: 400px;
            width: 100%;
        }

        .plinko-board {
            width: 100%;
        }
    }
</style>